{
  "name": "forge-protocol",
  "version": "0.3.0",
  "description": "Design-first development protocol for AI-Human collaboration",
  "type": "module",
  "bin": {
    "forge": "./bin/forge.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "lib/",
    "shared/",
    "templates/commerce/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node bin/forge.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"lib/**/*.js\" \"bin/**/*.js\" \"test/**/*.js\"",
    "format:check": "prettier --check \"lib/**/*.js\" \"bin/**/*.js\" \"test/**/*.js\""
  },
  "keywords": [
    "forge",
    "protocol",
    "ai",
    "vibe-coding",
    "cli",
    "ai-coding",
    "design-first",
    "development-protocol",
    "block-architecture",
    "dependency-resolution"
  ],
  "author": "DevSmith (Jinik)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devsmith-kr/forge-protocol.git"
  },
  "homepage": "https://github.com/devsmith-kr/forge-protocol#readme",
  "bugs": {
    "url": "https://github.com/devsmith-kr/forge-protocol/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.3.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.4"
  }
}
